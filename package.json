{
  "name": "open-graph-types",
  "description": "📦️ Ultra-lightweight and strict Open Graph TypeScript definitions.",
  "author": "Luis Monsalve",
  "version": "1.0.1",
  "homepage": "https://github.com/TheElegantCoding/open-graph-types#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TheElegantCoding/open-graph-types.git"
  },
  "keywords": [
    "typescript",
    "open-graph",
    "ogp",
    "types"
  ],
  "bugs": {
    "url": "https://github.com/TheElegantCoding/open-graph-types/issues"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["./dist"],
  "engines": {
    "node": ">=22.17.0",
    "bun": ">=1.1.0"
  },
  "scripts": {
    "preinstall": "npx only-allow bun",
    "postinstall": "bunx gitlys init",
    "release": "bun run build && bunx gitlys release",
    "prepublishOnly": "bun run build",
    "lint": "eslint . --fix ",
    "build": "tsup"
  },
  "devDependencies": {
    "eslint-config-universal-code": "^1.0.13",
    "gitlys": "^1.1.5",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3"
  }
}
